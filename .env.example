# Copie ce fichier en ".env" pour du dev local avec des vraies variables,
# ou configure ces mêmes variables directement dans Railway (onglet "Variables").

SECRET_KEY=change-moi-en-une-longue-chaine-aleatoire
DEBUG=False
ALLOWED_HOSTS=ton-app.up.railway.app
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://ton-app.com

# DATABASE_URL est fournie automatiquement par Railway quand tu ajoutes
# un plugin PostgreSQL -- tu n'as normalement rien à faire pour celle-ci.
